# The top-level .gitignore excludes *.json globally (line ~178).
# Re-admit the files this harness needs.

# Checked-in fixtures
!sample_conversations.json
!sample_gold.json

# Only commit baseline-*.json. Per-run scored results and
# intermediate prediction files are transient and stay local.
results/*.json
!results/baseline-*.json

# LLM Judge cache — contains question/gold/prediction hashes + LLM responses.
# Large, ephemeral, never committed.
results/.llm_judge_cache.json
results/.llm_judge_cache.json.tmp
