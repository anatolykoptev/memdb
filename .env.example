# MemDB — Go stack self-hosting configuration
# Copy to .env and fill in the required values before running docker compose.
#
# Required fields are marked [required].
# Optional fields can be left at their defaults for a minimal local deployment.

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=memdb
POSTGRES_PASSWORD=change-me-to-something-strong   # [required] change before deploy
POSTGRES_DB=memdb

# Connection URL used by memdb-go (references the vars above)
MEMDB_POSTGRES_URL=postgresql://memdb:change-me-to-something-strong@postgres:5432/memdb

# ── LLM provider ─────────────────────────────────────────────────────────────
# Any OpenAI-compatible base URL works: OpenAI, OpenRouter, LiteLLM, Ollama, etc.
# See docs/llm-providers.md for alternatives.
MEMDB_LLM_PROXY_URL=https://api.openai.com/v1
MEMDB_LLM_API_KEY=sk-...   # [required] your API key
MEMDB_LLM_MODEL=gpt-4o-mini

# ── Embeddings ───────────────────────────────────────────────────────────────
# Set MEMDB_EMBEDDER_TYPE=http and point at an embed-server sidecar for
# local GPU/CPU embeddings (see docs/embed-server.md).
# Alternatively use MEMDB_EMBEDDER_TYPE=ollama or voyage (VoyageAI).
MEMDB_EMBEDDER_TYPE=http
MEMDB_EMBED_URL=http://embed-server:8080   # active when embed-server profile is enabled

# ── Logging ──────────────────────────────────────────────────────────────────
MEMDB_LOG_LEVEL=info    # debug | info | warn | error
MEMDB_LOG_FORMAT=json   # json | text
