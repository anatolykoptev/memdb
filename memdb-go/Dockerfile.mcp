# ─── Build stage ─────────────────────────────────────────────────────
# MCP server — no ONNX/CGO needed (search proxied to memdb-go).
FROM golang:1.26rc3 AS builder

WORKDIR /app

# Copy source with vendored dependencies
COPY . .

# Build MCP server as static binary (no CGO, vendored deps)
RUN CGO_ENABLED=0 go build -mod=vendor -ldflags="-s -w" -o /memdb-mcp ./cmd/mcp-server

# ─── Runtime stage ───────────────────────────────────────────────────
FROM debian:trixie-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates && \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /memdb-mcp /usr/local/bin/memdb-mcp

EXPOSE 8001

ENTRYPOINT ["memdb-mcp"]
